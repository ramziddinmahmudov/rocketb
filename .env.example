# ── Antigravity (Rocket Battle) — Environment Variables ────
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# ── Telegram Bot ───────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# ── WebApp URL ─────────────────────────────────────────────
# Public URL where the React frontend is deployed.
# This is used in the /start inline button (WebAppInfo).
# For local testing, use ngrok: ngrok http 80
WEBAPP_URL=https://yourdomain.com

# ── PostgreSQL ─────────────────────────────────────────────
# When using docker-compose, these are auto-overridden.
POSTGRES_USER=antigravity
POSTGRES_PASSWORD=secret
POSTGRES_DB=antigravity
DATABASE_URL=postgresql+asyncpg://antigravity:secret@localhost:5432/antigravity

# ── Redis ──────────────────────────────────────────────────
# When using docker-compose, this is auto-overridden.
REDIS_URL=redis://localhost:6379/0

# ── CORS (optional) ───────────────────────────────────────
# Comma-separated list of allowed origins. Default: * (all).
# For production: CORS_ORIGINS=https://yourdomain.com
CORS_ORIGINS=*

# ── WebApp Secret (optional) ──────────────────────────────
# Used for HMAC validation of Telegram initData.
# If empty, BOT_TOKEN is used automatically.
WEBAPP_SECRET=https://rocketb-e2e9.vercel.app/
